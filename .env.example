SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Optional: use this only if your `daily_logs` table RLS blocks anon writes.
# Using a service role key bypasses RLS, so keep it secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct Postgres connection — needed for migrations only
# Find it: Supabase Dashboard → Settings → Database → Connection string (URI tab)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[your-project-ref].supabase.co:5432/postgres
